#!/bin/zsh
set -euo pipefail

HELPER="/usr/local/libexec/magsafe-led-helper"
STATE_DIR="${TMPDIR:-/tmp}/magsafe-dark-${UID}"
RESET_PID="$STATE_DIR/reset.pid"
TEMP_STATE="$STATE_DIR/temporary.state"
DEFAULTS_DOMAIN="su.xyz.MagSafeDark"

mkdir -p "$STATE_DIR"

read_default() {
  /usr/bin/defaults read "$DEFAULTS_DOMAIN" "$1" 2>/dev/null || true
}

SUCCESS_SECONDS="${MAGSAFE_DARK_SUCCESS_SECONDS:-$(read_default codexSuccessSeconds)}"
ERROR_SECONDS="${MAGSAFE_DARK_ERROR_SECONDS:-$(read_default codexErrorSeconds)}"
NOTIFICATIONS="${MAGSAFE_DARK_NOTIFICATIONS:-$(read_default codexNotifications)}"
SUCCESS_SECONDS="${SUCCESS_SECONDS:-5}"
ERROR_SECONDS="${ERROR_SECONDS:-5}"
NOTIFICATIONS="${NOTIFICATIONS:-1}"

usage() {
  cat <<'EOF'
Usage: magsafe-dark <command> [arguments]

States:
  working                 Orange while a task is running
  success                 Green, then system mode after a delay
  error                   Orange, then system mode after a delay
  idle                    Restore system-controlled mode

Direct LED modes:
  off | system | green | orange
  flash                   Single error indication
  blink-slow              Slow orange blinking
  blink-fast              Fast orange blinking
  blink-off               Blink orange, then switch off
  status                  Print the raw ACLC value

Timers:
  for <seconds> <mode>     Set a mode temporarily, then restore system mode
  timer-status             Print remaining timer seconds, or nothing
  cancel-timer             Cancel timer and restore system mode
  temporary-active         Exit 0 while a timer or automation state is active

Command runner:
  run [--working MODE] [--success MODE] [--error MODE] [--delay SEC] -- COMMAND...
EOF
}

clear_state() {
  rm -f "$TEMP_STATE"
}

cancel_reset() {
  if [[ -f "$RESET_PID" ]]; then
    local pid
    pid="$(cat "$RESET_PID" 2>/dev/null || true)"
    [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
    rm -f "$RESET_PID"
  fi
  clear_state
}

set_mode() { sudo -n "$HELPER" "$1" >/dev/null; }

write_state() {
  local kind="$1" end="$2" mode="$3"
  printf '%s\t%s\t%s\n' "$kind" "$end" "$mode" > "$TEMP_STATE"
}

schedule_system() {
  local seconds="$1" kind="${2:-automation}" mode="${3:-system}"
  local end=$(( $(date +%s) + seconds ))
  write_state "$kind" "$end" "$mode"
  (
    sleep "$seconds"
    sudo -n "$HELPER" system >/dev/null 2>&1 || true
    rm -f "$RESET_PID" "$TEMP_STATE"
  ) >/dev/null 2>&1 &
  echo $! > "$RESET_PID"
}

state_is_active() {
  [[ -f "$TEMP_STATE" ]] || return 1
  local kind end mode now
  IFS=$'\t' read -r kind end mode < "$TEMP_STATE" || return 1
  now=$(date +%s)
  if [[ "$end" == "0" || "$end" -gt "$now" ]]; then
    return 0
  fi
  rm -f "$TEMP_STATE" "$RESET_PID"
  return 1
}

notify() {
  [[ "$NOTIFICATIONS" == "1" ]] || return 0
  /usr/bin/osascript -e "display notification \"$2\" with title \"MagSafe Dark\" subtitle \"$1\"" >/dev/null 2>&1 || true
}

valid_mode() {
  case "$1" in
    off|system|green|orange|flash|blink-slow|blink-fast|blink-off) return 0 ;;
    *) return 1 ;;
  esac
}

run_command() {
  local working="orange" success="green" failure="orange" delay="$SUCCESS_SECONDS"
  shift
  while (( $# )); do
    case "$1" in
      --working) working="$2"; shift 2 ;;
      --success) success="$2"; shift 2 ;;
      --error) failure="$2"; shift 2 ;;
      --delay) delay="$2"; shift 2 ;;
      --) shift; break ;;
      *) print -u2 "Unknown run option: $1"; exit 64 ;;
    esac
  done
  (( $# )) || { print -u2 "Missing command after --"; exit 64; }
  valid_mode "$working" && valid_mode "$success" && valid_mode "$failure" || {
    print -u2 "Invalid LED mode for run command"; exit 64
  }

  cancel_reset
  set_mode "$working"
  write_state automation 0 "$working"
  set +e
  "$@"
  local code=$?
  set -e
  if (( code == 0 )); then
    set_mode "$success"
    notify "Command completed" "Success"
  else
    set_mode "$failure"
    notify "Command completed" "Error, code $code"
  fi
  schedule_system "$delay" automation "${code}:${success}:${failure}"
  return "$code"
}

[[ -x "$HELPER" ]] || {
  print -u2 "MagSafe Dark helper is not installed. Run ./install.sh first."
  exit 127
}

command="${1:-}"
case "$command" in
  working)
    cancel_reset; set_mode orange; write_state automation 0 orange
    ;;
  success)
    cancel_reset; set_mode green; notify "Codex" "Task completed"; schedule_system "$SUCCESS_SECONDS" automation green
    ;;
  error)
    cancel_reset; set_mode orange; notify "Codex" "Task failed"; schedule_system "$ERROR_SECONDS" automation orange
    ;;
  idle|system)
    cancel_reset; set_mode system
    ;;
  off|green|orange|flash|blink-slow|blink-fast|blink-off)
    cancel_reset; set_mode "$command"
    ;;
  status)
    sudo -n "$HELPER" status
    ;;
  for)
    seconds="${2:-}"; mode="${3:-}"
    [[ "$seconds" == <-> ]] || { print -u2 "Seconds must be an integer"; exit 64; }
    valid_mode "$mode" || { print -u2 "Unknown mode: $mode"; exit 64; }
    cancel_reset; set_mode "$mode"; schedule_system "$seconds" timer "$mode"
    ;;
  timer-status)
    if state_is_active; then
      IFS=$'\t' read -r kind end mode < "$TEMP_STATE"
      if [[ "$kind" == "timer" ]]; then
        now=$(date +%s)
        remaining=$(( end - now ))
        (( remaining < 0 )) && remaining=0
        print "$remaining"
      fi
    fi
    ;;
  temporary-active)
    state_is_active
    ;;
  cancel-timer)
    if state_is_active; then
      IFS=$'\t' read -r kind end mode < "$TEMP_STATE"
      [[ "$kind" == "timer" ]] || exit 0
    fi
    cancel_reset
    set_mode system
    ;;
  run)
    run_command "$@"
    ;;
  -h|--help|help|"") usage ;;
  *) print -u2 "Unknown command: $command"; usage >&2; exit 64 ;;
esac